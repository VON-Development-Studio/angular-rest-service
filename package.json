{
  "name": "@von-development-studio/angular-rest-service",
  "version": "0.0.0",
  "description": "Angular Rest Service wrapper.",
  "repository": {
    "type": "git",
    "url": "https://github.com/VON-Development-Studio/angular-rest-service"
  },
  "keywords": [
    "angular",
    "rest client"
  ],
  "author": "Luis García Castro",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve example",
    "build": "ng build",
    "build:lib": "ng build --configuration production ng-rest-service",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "publish:rel": "cd dist/ng-rest-service && npm publish --tag latest --access public",
    "publish:snapshot": "cd dist/ng-rest-service && npm publish --tag snapshot --access public"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.18",
    "@angular/common": "^19.2.18",
    "@angular/compiler": "^19.2.18",
    "@angular/core": "^19.2.18",
    "@angular/forms": "^19.2.18",
    "@angular/platform-browser": "^19.2.18",
    "@angular/platform-browser-dynamic": "^19.2.18",
    "@angular/router": "^19.2.18",
    "rxjs": "~7.8.0",
    "tslib": "^2.4.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.19",
    "@angular/cli": "^19.2.19",
    "@angular/compiler-cli": "^19.2.18",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^19.2.2",
    "typescript": "~5.5.2"
  }
}
